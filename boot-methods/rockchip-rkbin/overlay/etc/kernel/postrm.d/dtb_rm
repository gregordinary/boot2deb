# kernel post-remove hook: /etc/kernel/postrm.d
# delete the board dtb from /boot after a kernel is removed. The dtb name comes
# from /etc/boot2deb/board.conf (generated from the device's kernel_dtb).

version="$1"

# passing the kernel version is required
if [ -z "${version}" ]; then
	echo >&2 "E: dtb_rm: ${DPKG_MAINTSCRIPT_PACKAGE:-kernel package} did not pass a version number"
	exit 2
fi

if [ -e /etc/boot2deb/board.conf ]; then
	. /etc/boot2deb/board.conf
	target="/boot/${DTB_NAME}-${version}"
	echo "I: dtb_rm: cleaning up ${target}"
	rm -f "${target}"
fi
