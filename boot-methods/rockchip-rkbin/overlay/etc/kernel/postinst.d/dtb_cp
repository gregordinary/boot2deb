# kernel post-install hook: /etc/kernel/postinst.d
# copy the board dtb into /boot after a new kernel is installed. The dtb name
# comes from /etc/boot2deb/board.conf (generated from the device's kernel_dtb),
# so this boot-method hook stays board-agnostic.

version="$1"

# passing the kernel version is required
if [ -z "${version}" ]; then
	echo >&2 "E: dtb_cp: ${DPKG_MAINTSCRIPT_PACKAGE:-kernel package} did not pass a version number"
	exit 2
fi

if [ ! -e /etc/boot2deb/board.conf ]; then
	echo >&2 "E: dtb_cp: /etc/boot2deb/board.conf missing (board dtb name unknown)"
	exit 4
fi
. /etc/boot2deb/board.conf

source1="/boot/${DTB_NAME}"
source2="/usr/lib/linux-image-${version}/${DTB_PATH}"
target="/boot/${DTB_NAME}-${version}"

if [ -e "${source1}" ]; then
	echo -n "I: dtb_cp: symlink "
	ln -sfv "$(basename "${source1}")" "${target}"
elif [ -e "${source2}" ]; then
	echo "I: dtb_cp: installing ${source2} to ${target}"
	install -vm 644 "${source2}" "${target}"
else
	echo >&2 "E: dtb_cp: neither ${source1} nor ${source2} found"
	exit 3
fi
