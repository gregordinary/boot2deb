# accel/full -- RK3588 media + compute acceleration (curated slice).
# VDPU decode (VIDEO_ROCKCHIP_VDEC), VEPU encode (VIDEO_ROCKCHIP_RKVENC), RGA multicore
# out-of-tree driver (ROCKCHIP_MULTI_RGA -- the in-tree VIDEO_ROCKCHIP_RGA is left off),
# rocket NPU (DRM_ACCEL_ROCKET), Hantro, ISP1, VSI IOMMU. These symbols exist only after
# the media-accel + rocket patch series is applied; the effective values are from the
# RK1 config on v7.1.1.

CONFIG_DRM_ACCEL=y
CONFIG_DRM_ACCEL_ROCKET=m
CONFIG_ROCKCHIP_MULTI_RGA=m
CONFIG_ROCKCHIP_RGA_ASYNC=y
CONFIG_ROCKCHIP_RGA_DEBUGGER=y
CONFIG_ROCKCHIP_RGA_DEBUG_FS=y
CONFIG_VIDEO_HANTRO_HEVC_RFC=y
# CONFIG_VIDEO_HANTRO_IMX8M is not set
# CONFIG_VIDEO_HANTRO_STM32MP25 is not set
# CONFIG_VIDEO_HANTRO_SUNXI is not set
# CONFIG_VIDEO_ROCKCHIP_CIF is not set
CONFIG_VIDEO_ROCKCHIP_ISP1=m
# CONFIG_VIDEO_ROCKCHIP_RGA is not set
CONFIG_VIDEO_ROCKCHIP_RKVENC=m
CONFIG_VIDEO_ROCKCHIP_VDEC=m
