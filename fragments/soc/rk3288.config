# fragments/soc/rk3288.config — RK3288 platform drivers, shared by every RK3288
# board. Merged after base/debian-armhf, before any device fragment.
#
# Everything the Veyron initramfs module list (socs/rk3288 overlay-pre
# modules.d/veyron) names must exist as a module (=m) for the built kernel: the
# rootfs stage hard-fails the build if a listed module has no .ko or does not
# land in the initrd. Keep those symbols =m here, never =y.

# Boot-critical path (initramfs modules): I2C, PMIC, clock, MMC, SPI, EC, USB
CONFIG_I2C_RK3X=m
# rk8xx PMIC: MFD core and its I2C transport are built in; the regulator and
# clock drivers stay modular because modules.d/veyron loads them in the
# initramfs (a listed module must exist as a .ko).
CONFIG_MFD_RK8XX=y
CONFIG_MFD_RK8XX_I2C=y
CONFIG_PINCTRL_RK805=y
CONFIG_RTC_DRV_RK808=y
CONFIG_REGULATOR_RK808=m
CONFIG_COMMON_CLK_RK808=m
CONFIG_MMC_DW=m
CONFIG_MMC_DW_PLTFM=m
CONFIG_MMC_DW_ROCKCHIP=m
CONFIG_SPI_ROCKCHIP=m
CONFIG_ROCKCHIP_IODOMAIN=m
CONFIG_PHY_ROCKCHIP_USB=m
CONFIG_USB_DWC2=m
CONFIG_USB_EHCI_HCD_PLATFORM=m
CONFIG_USB_OHCI_HCD_PLATFORM=m
CONFIG_CHROME_PLATFORMS=y
CONFIG_CROS_EC=m
CONFIG_CROS_EC_SPI=m
CONFIG_KEYBOARD_CROS_EC=m
CONFIG_I2C_CROS_EC_TUNNEL=m

# Platform
CONFIG_ROCKCHIP_THERMAL=m
CONFIG_PWM_ROCKCHIP=m
CONFIG_BACKLIGHT_PWM=m
CONFIG_DW_WATCHDOG=m
CONFIG_NVMEM_ROCKCHIP_EFUSE=m

# Display + GPU: rockchip-drm (VOP/eDP/HDMI) and panfrost (Mali T760)
CONFIG_DRM_ROCKCHIP=m
CONFIG_ROCKCHIP_ANALOGIX_DP=y
CONFIG_ROCKCHIP_DW_HDMI=y
CONFIG_ROCKCHIP_VOP=y
CONFIG_DRM_PANFROST=m

# Media: the SoC layer force-loads hantro_vpu and rockchip_vdec (modules-load.d),
# so both must be =m
CONFIG_VIDEO_HANTRO=m
CONFIG_VIDEO_ROCKCHIP_VDEC=m
CONFIG_VIDEO_ROCKCHIP_RGA=m

# Crypto engine: kept enabled on purpose — the rk3288-fixes profile repairs its
# hash self-tests, and this recipe is where that fix is proven on hardware
CONFIG_CRYPTO_DEV_ROCKCHIP=m

# Audio: I2S + max98090 (Veyron codec)
CONFIG_SND_SOC_ROCKCHIP_I2S=m
CONFIG_SND_SOC_ROCKCHIP_MAX98090=m

# UBSAN's shift check is a diagnostic, not a driver: on 32-bit it flags a benign
# out-of-range shift in the generic iommu pagetable path at every panfrost start
# (io-pgtable-arm.c, 40-bit OAS vs 32-bit phys_addr_t). Debian ships it enabled;
# this kernel does not carry the noise.
# CONFIG_UBSAN_SHIFT is not set
