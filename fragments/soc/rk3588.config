# socs/rk3588 -- RK3588 platform drivers (curated slice).
# clk / pinctrl / phy / pcie / thermal / saradc / crypto / nvmem / regulator (RK808) /
# sound-soc / display (DRM_ROCKCHIP). Values are the effective RK1 config on
# v7.1.1. Shared by every RK3588 board on this kernel; board deltas go in device/.

CONFIG_ARM_RK3399_DMC_DEVFREQ=y
CONFIG_CAN_ROCKCHIP_CANFD=m
# CONFIG_CHARGER_RK817 is not set
CONFIG_COMMON_CLK_RK808=m
CONFIG_CRYPTO_DEV_ROCKCHIP=y
CONFIG_DEVFREQ_EVENT_ROCKCHIP_DFI=y
CONFIG_DRM_ROCKCHIP=y
CONFIG_DWMAC_ROCKCHIP=y
# CONFIG_INPUT_RK805_PWRKEY is not set
CONFIG_MTD_NAND_ROCKCHIP=m
CONFIG_NVMEM_ROCKCHIP_EFUSE=m
CONFIG_NVMEM_ROCKCHIP_OTP=m
CONFIG_PCIE_ROCKCHIP_DW_EP=y
CONFIG_PCIE_ROCKCHIP_EP=y
CONFIG_PCIE_ROCKCHIP_HOST=y
CONFIG_PHY_ROCKCHIP_DP=y
CONFIG_PHY_ROCKCHIP_DPHY_RX0=m
CONFIG_PHY_ROCKCHIP_INNO_CSIDPHY=m
CONFIG_PHY_ROCKCHIP_INNO_DSIDPHY=y
CONFIG_PHY_ROCKCHIP_INNO_HDMI=y
CONFIG_PHY_ROCKCHIP_NANENG_COMBO_PHY=y
CONFIG_PHY_ROCKCHIP_PCIE=y
# CONFIG_PHY_ROCKCHIP_SAMSUNG_HDPTX is not set
CONFIG_PHY_ROCKCHIP_SNPS_PCIE3=m
CONFIG_PHY_ROCKCHIP_USB=y
CONFIG_PHY_ROCKCHIP_USBDP=y
CONFIG_REGULATOR_RK808=m
# CONFIG_ROCKCHIP_DW_DP is not set
CONFIG_ROCKCHIP_MBOX=y
CONFIG_ROCKCHIP_RGB=y
CONFIG_ROCKCHIP_RK3066_HDMI=y
CONFIG_ROCKCHIP_SARADC=y
CONFIG_ROCKCHIP_THERMAL=y
# CONFIG_SCSI_UFS_ROCKCHIP is not set
CONFIG_SND_SOC_INNO_RK3036=m
CONFIG_SND_SOC_RK3288_HDMI_ANALOG=m
# CONFIG_SND_SOC_RK3308 is not set
CONFIG_SND_SOC_RK3328=m
# CONFIG_SND_SOC_RK817 is not set
# CONFIG_SND_SOC_ROCKCHIP_I2S_TDM is not set
CONFIG_SND_SOC_ROCKCHIP_MAX98090=m
CONFIG_SND_SOC_ROCKCHIP_PDM=m
# CONFIG_SND_SOC_ROCKCHIP_SAI is not set
CONFIG_SPI_ROCKCHIP_SFC=y
